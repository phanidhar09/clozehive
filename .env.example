# ─────────────────────────────────────────────────────────────
#  CLOZEHIVE — Root environment variables
#  Copy this file to .env and fill in your values.
#  Never commit the real .env file.
# ─────────────────────────────────────────────────────────────

# ── Ports ────────────────────────────────────────────────────
FRONTEND_PORT=3000
API_GATEWAY_PORT=8000
AI_AGENT_PORT=8001

# ── Derived service URLs ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000
AI_AGENT_URL=http://localhost:8001

# ── OpenAI ───────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-64-character-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ── Data stores ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clozehive:clozehive@localhost:5433/clozehive
REDIS_URL=redis://localhost:6380/0

# ── Vector search ─────────────────────────────────────────────
VECTOR_STORE=pgvector
VECTOR_SEARCH_LIMIT=8
VECTOR_SCORE_THRESHOLD=0.78
