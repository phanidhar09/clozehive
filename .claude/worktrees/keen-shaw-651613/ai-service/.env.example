# ─────────────────────────────────────────────────────────────
#  CLOZEHIVE AI Service — environment variables
#  Copy this file to .env and fill in your values.
#  Note: OPENAI_API_KEY is inherited from the root .env
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
AI_SERVICE_HOST=0.0.0.0
DEBUG=true
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────────────
# OPENAI_API_KEY is loaded from root .env (no need to repeat)
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional — leave blank if not using)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Which provider to use: openai | anthropic
LLM_PROVIDER=openai

# ── Embeddings ───────────────────────────────────────────────
# local = no API cost (uses sentence-transformers)
# openai = uses text-embedding-3-small
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store (FAISS) ─────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index

# ── Database ─────────────────────────────────────────────────
SQLITE_DB_PATH=../backend/data/closetiq.db

# ── RAG settings ─────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
RAG_MAX_TOKENS=2000

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173
