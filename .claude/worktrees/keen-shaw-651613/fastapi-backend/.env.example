# ─────────────────────────────────────────────────────────────────────────────
#  ClozéHive FastAPI — environment variables
#
#  Copy this file:  cp .env.example .env
#  Fill in every CHANGE_ME value before running the app.
#  NEVER commit the real .env file (it is git-ignored).
#
#  Minimum viable dev setup (run in order):
#    1. Fill in SECRET_KEY, POSTGRES_PASSWORD, and OPENAI_API_KEY below.
#    2. docker compose up -d postgres redis
#    3. alembic upgrade head
#    4. uvicorn app.main:app --reload
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_NAME=CLOZEHIVE API
APP_VERSION=1.0.0
DEBUG=true                              # set false in production

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Optional separate CSRF signing key.
# Falls back to SECRET_KEY if left blank.
CSRF_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
API_PORT=8000                           # host-side port exposed by docker compose

# ── Database ──────────────────────────────────────────────────────────────────
# These are used both by the app and by docker-compose to configure postgres.
POSTGRES_USER=clozehive
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=clozehive

# Full URLs (docker-compose overrides the host to the service name automatically)
DATABASE_URL=postgresql+asyncpg://clozehive:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/clozehive
SYNC_DATABASE_URL=postgresql+psycopg2://clozehive:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/clozehive

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave REDIS_PASSWORD blank to disable Redis AUTH (local dev only).
# In production, always set a strong password.
REDIS_PASSWORD=
# If REDIS_PASSWORD is set, include it in the URL: redis://:PASSWORD@host:6379/0
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15          # short-lived access tokens (15 min recommended)
REFRESH_TOKEN_EXPIRE_DAYS=7            # rotating refresh tokens (7 days)
JWT_ALGORITHM=HS256

# ── Session / cookie security ─────────────────────────────────────────────────
# COOKIE_SECURE must be true in production (requires HTTPS).
COOKIE_SECURE=false                     # true in production
# COOKIE_SAMESITE: "lax" works for most setups; "none" required for cross-site.
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN: leave blank to use the request domain.
COOKIE_DOMAIN=

# ── CSRF protection ───────────────────────────────────────────────────────────
# Double-Submit Cookie pattern — the client reads this cookie and echoes it
# back as the X-CSRF-Token header on every state-mutating request.
CSRF_COOKIE_NAME=csrftoken
CSRF_HEADER_NAME=x-csrf-token

# ── Account security ──────────────────────────────────────────────────────────
# Lock the account after this many consecutive failed login attempts…
MAX_LOGIN_ATTEMPTS=5
# …for this many minutes.
LOCKOUT_DURATION_MINUTES=15

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute           # applied to all routes
RATE_LIMIT_AUTH=10/minute              # /login, /signup, /google endpoints
RATE_LIMIT_REFRESH=30/minute           # /refresh endpoint (token rotation)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace with your actual domain(s).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
OPENAI_API_KEY=sk-CHANGE_ME

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave blank to disable Google sign-in (returns 501 from /auth/google).
# Obtain credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_PROFILE=300
CACHE_TTL_CLOSET=120
CACHE_TTL_WEATHER=600
