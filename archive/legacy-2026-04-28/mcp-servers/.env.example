# ─────────────────────────────────────────────────────────────
#  CLOZEHIVE MCP Servers — environment variables
#  These are picked up from the root .env automatically via
#  shared/config.py (SettingsConfigDict env_file=../../.env).
#
#  If you want server-specific overrides, copy this to .env
#  inside the mcp-servers/ folder and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────
# Inherited from root .env:
# OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

LLM_PROVIDER=openai

# ── MCP Server ports ─────────────────────────────────────────
VISION_PORT=8001
OUTFIT_PORT=8002
PACKING_PORT=8003
WEATHER_PORT=8004

# ── Gateway ──────────────────────────────────────────────────
GATEWAY_PORT=8005

# ── Database ─────────────────────────────────────────────────
SQLITE_DB_PATH=../backend/data/closetiq.db

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173
