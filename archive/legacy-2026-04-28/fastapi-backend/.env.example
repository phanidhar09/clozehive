# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_NAME=CLOZEHIVE API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clozehive:secret@localhost:5432/clozehive
SYNC_DATABASE_URL=postgresql+psycopg2://clozehive:secret@localhost:5432/clozehive

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001          # existing Python AI service
OPENAI_API_KEY=sk-...

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_PROFILE=300
CACHE_TTL_CLOSET=120
CACHE_TTL_WEATHER=600
